{
  "name": "@iletimerkezi/mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the iletiMerkezi SMS API. Lets LLMs send SMS, query delivery reports, manage senders and blacklists through tool calls.",
  "license": "MIT",
  "author": "eMarka İletişim ve Bilgi Teknolojileri A.Ş.",
  "homepage": "https://www.iletimerkezi.com/docs/api/overview",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iletimerkezi/iletimerkezi-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/iletimerkezi/iletimerkezi-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "iletimerkezi",
    "sms",
    "sms-api",
    "turkey",
    "claude",
    "anthropic"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "iletimerkezi-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "fetch-fallback": "node scripts/fetch-fallback-manifest.mjs",
    "prepublishOnly": "npm run fetch-fallback && npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
